{
  "query": "\n-- Get services for DataGate customers - understand what services exist\nSELECT s.externalId, s.serviceType, s.serviceTypeDetail, s.planName, s.customerName, s.customerExternalId, s.monthlyRevenue, s.monthlyCost\nFROM services s\nJOIN customers c ON s.customerExternalId = c.externalId\nWHERE (c.billingPlatforms LIKE '%DataGate%' OR c.billingPlatforms LIKE '%DATAGATE%')\nAND s.status = 'active'\nORDER BY s.customerName, s.serviceType\nLIMIT 20;\n",
