  "query": "\n-- Find entries with no internalCustomerExternalId (unlinked) or low confidence\nSELECT \n  octaneCustomerId,\n  octaneCustomerName,\n  octaneServiceName,\n  internalCustomerExternalId,\n  internalCustomerName,\n  matchType,\n  matchConfidence,\n  isZambreroService\nFROM octane_customer_links\nWHERE internalCustomerExternalId IS NULL \n   OR matchConfidence < 80\n   OR octaneCustomerName LIKE '%Zambrero%'\n   OR octaneCustomerName LIKE '%AHJ%'\n   OR octaneCustomerName LIKE '%Infinitea%'\n   OR octaneCustomerName LIKE '%Bel%'\nORDER BY matchConfidence ASC;\n",
