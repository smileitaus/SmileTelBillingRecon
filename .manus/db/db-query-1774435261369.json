{
  "query": "\n-- invoiceDate \"46054\" is an Excel date serial number (= 2026-02-01 in Excel)\n-- This means the same invoice was imported TWICE: once from a proper CSV and once from an Excel-formatted CSV\n-- Find all billing items where invoiceDate looks like an Excel serial number (5-digit number)\nSELECT COUNT(*) AS excel_date_items FROM billing_items WHERE invoiceDate REGEXP '^[0-9]{5}$';\n\n-- Find duplicate billing items: same invoiceNumber + same description but different invoiceDate format\nSELECT \n  invoiceNumber, \n  description,\n  COUNT(*) AS cnt,\n  GROUP_CONCAT(externalId ORDER BY externalId SEPARATOR ', ') AS item_ids,\n  GROUP_CONCAT(invoiceDate ORDER BY externalId SEPARATOR ', ') AS dates\nFROM billing_items\nGROUP BY invoiceNumber, description\nHAVING COUNT(*) > 1\nORDER BY cnt DESC\nLIMIT 10;\n",
